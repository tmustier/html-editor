{
  "name": "html-editor",
  "private": true,
  "type": "module",
  "description": "Local HTML collaboration editor with optional Pi session comment bridge.",
  "scripts": {
    "test": "./scripts/test.sh",
    "test:fast": "./scripts/test.sh --fast",
    "e2e": "playwright test"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1"
  },
  "keywords": [
    "pi-package",
    "pi",
    "html",
    "editor",
    "collaboration"
  ],
  "pi": {
    "extensions": [
      "./extensions/html-editor-comments.ts"
    ],
    "skills": [
      "./skills"
    ]
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*"
  },
  "peerDependenciesMeta": {
    "@earendil-works/pi-coding-agent": {
      "optional": true
    }
  },
  "version": "0.1.3",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tmustier/html-editor.git"
  }
}
