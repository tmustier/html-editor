{
  "name": "html-editor",
  "private": true,
  "type": "module",
  "description": "Local HTML collaboration editor with optional Pi session comment bridge.",
  "engines": {
    "node": ">=20.19"
  },
  "scripts": {
    "test": "./scripts/test.sh",
    "test:fast": "./scripts/test.sh --fast",
    "e2e": "playwright test",
    "lint": "npm run lint:js && npm run lint:py",
    "lint:js": "eslint client/ tests/e2e/ scripts/*.mjs playwright.config.js eslint.config.js",
    "lint:py": "./scripts/ruff.sh check serve.py server/ tests/ scripts/*.py",
    "bench:browser": "node scripts/bench_browser_table_ops.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.49.1",
    "eslint": "^10.4.0"
  },
  "keywords": [
    "pi-package",
    "pi",
    "html",
    "editor",
    "collaboration"
  ],
  "pi": {
    "extensions": [
      "./extensions/html-editor-comments.ts"
    ],
    "skills": [
      "./skills"
    ]
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*"
  },
  "peerDependenciesMeta": {
    "@earendil-works/pi-coding-agent": {
      "optional": true
    }
  },
  "version": "0.2.1",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tmustier/html-editor.git"
  }
}
